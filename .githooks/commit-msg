#!/usr/bin/env bash
set -euo pipefail

message_file="$1"
first_line="$(head -n 1 "$message_file")"

if [[ ! "$first_line" =~ ^(feat|fix|docs|chore|refactor|test|ops|data)(\([a-z0-9_-]+\))?:\ .+ ]]; then
  echo "Commit message must use Conventional Commits, for example: feat: add reef controls" >&2
  exit 1
fi

